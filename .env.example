# Application runtime
APP_ENV=development
FLASK_DEBUG=1
PORT=5000

# Data backend: inmemory or postgres
DATA_BACKEND=inmemory

# PostgreSQL connection (used when DATA_BACKEND=postgres)
DATABASE_URL=postgresql+psycopg://poker_user:dev_password@localhost:5432/scrum_poker

# SocketIO secret
SECRET_KEY=change-me
