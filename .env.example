# Application environment: development | testing | postgres
APP_ENV=development

# Storage backend: inmemory (default for local dev) | postgres
DATA_BACKEND=inmemory

# Flask session secret — CHANGE THIS before running in any non-local environment
SECRET_KEY=dev-only-insecure-secret-change-before-deploy

# Enable Flask debug mode (development only — do not set in production)
FLASK_DEBUG=1

# PostgreSQL connection string (only required when DATA_BACKEND=postgres)
DATABASE_URL=postgresql+psycopg://poker_user:dev_password@localhost:5432/scrum_poker
